rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // App perso : lecture/écriture réservées aux comptes autorisés.
    // Remplacez la liste par votre (vos) UID Firebase, OU laissez `true` dans
    // isAllowed() pour autoriser tout utilisateur connecté.
    function isAllowed() {
      return request.auth != null;
      // Variante verrouillée à un compte précis :
      // return request.auth != null && request.auth.uid in ['VOTRE_UID'];
    }

    // Les offres sont écrites par le backend (Admin SDK, qui bypasse ces règles).
    // Depuis l'app : lecture, et écriture limitée aux champs `is_read` / `is_favorite`.
    match /offers/{offerId} {
      allow read: if isAllowed();
      allow update: if isAllowed()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read', 'is_favorite']);
      allow create, delete: if false; // réservé au backend
    }

    match /scrape_runs/{runId} {
      allow read: if isAllowed();
      allow write: if false; // réservé au backend
    }

    // Fiches entreprises (localisation) : lues par l'app, écrites par le backend.
    match /companies/{companyId} {
      allow read: if isAllowed();
      allow write: if false; // réservé au backend (Admin SDK)
    }

    // Recherches surveillées par le cron : gérées depuis l'app (phase 2).
    match /searches/{searchId} {
      allow read, write: if isAllowed();
    }

    // Profil candidat : lu par l'app pour l'afficher ; écrit par le backend
    // (Admin SDK). On autorise aussi l'écriture cliente (mono-utilisateur).
    match /profiles/{uid} {
      allow read, write: if isAllowed();
    }
  }
}
