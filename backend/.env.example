# --- Mistral (agents extraction / traduction) ---
MISTRAL_API_KEY=sk-...
MISTRAL_MODEL=mistral-small-latest

# --- Firebase Admin (écriture Firestore + push FCM) ---
# En local : chemin vers le service account JSON.
FIREBASE_CREDENTIALS_PATH=serviceAccount.json
# En prod (Render) : coller le JSON complet du service account sur une ligne.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# --- Sécurité : secret partagé exigé pour POST /scrape ---
API_SHARED_SECRET=change-me

# Note : les recherches du cron quotidien vivent dans la collection Firestore
# `searches` (amorcée avec config.DEFAULT_DAILY_SEARCHES), plus dans une env var.

# --- Réglages scraping (optionnels) ---
SCRAPE_MAX_PAGES=10
SCRAPE_MIN_DELAY=3
SCRAPE_MAX_DELAY=6
